#!/usr/bin/env bash
# Enforce CHANGELOG updates when template-affecting files change (skeleton repo only).
set -euo pipefail

root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
cd "$root"

# Only enforce when this checkout is the canonical skeleton (marker at git root).
if [[ ! -f SKELETON_REPO ]]; then
  exit 0
fi

changelog_staged=false
needs_log=false

while IFS= read -r f; do
  [[ -z "$f" ]] && continue
  if [[ "$f" == CHANGELOG.md ]]; then
    changelog_staged=true
  fi

  case "$f" in
    CHANGELOG.md|DEPRECATED_PATHS|.githooks/*|SKELETON_REPO|docs/skeleton-MAINTAINERS.md) continue ;;
  esac

  case "$f" in
    docs/*|.cursor/*|.claude/*|tasks/*|scripts/*|INIT.MD|CLAUDE.md|README.md|.gitignore|skeleton.manifest|push-skeleton|init-skeleton|sync-skeleton)
      needs_log=true
      ;;
  esac
done < <(git diff --cached --name-only --diff-filter=ACMRT)

if $needs_log && ! $changelog_staged; then
  echo "pre-commit: template paths are staged but CHANGELOG.md is not." >&2
  echo "Update CHANGELOG.md under [Unreleased] (and DEPRECATED_PATHS if deprecating), then stage CHANGELOG.md." >&2
  exit 1
fi

exit 0
