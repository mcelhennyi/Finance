# --- Baseline (skeleton; keep in sync with template intent) ---

# Dependencies
node_modules/
.venv/
.venv-*/

# Build / cache
dist/
build/
.cache/

# Environment
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.idea/
*.swp
*.swo

# Repo-local git worktrees (see docs/ai-context.md)
.worktrees/

# Logs
*.log

# --- Finance Hub (project-specific) ---

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# MkDocs
site/

# Database files
*.db
*.sqlite
*.sqlite3

# Sensitive financial data — never commit raw statements
data/raw/
data/uploads/
# Dev seed statements (drop CSVs here; tracked dir, ignored contents)
data/seed-statements/*
!data/seed-statements/.gitkeep
*.csv
*.pdf
!scripts/*.csv

# Environment (overrides and local files)
.env.local
.env.*.local

# IDE
.vscode/settings.json

# Reports (generated output) — exclude generated HTML but keep templates
reports/output/
*.html
!docs/**/*.html
!src/**/*.html
