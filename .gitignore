# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# MkDocs
site/

# Database files
*.db
*.sqlite
*.sqlite3

# Sensitive financial data — never commit raw statements
data/raw/
data/uploads/
*.csv
*.pdf
!scripts/*.csv  # allow fixture CSVs in scripts/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo
.DS_Store

# Reports (generated output) — exclude generated HTML but keep templates
reports/output/
*.html
!docs/**/*.html
!src/**/*.html
